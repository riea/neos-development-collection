{
    "name": "neos/contentrepository-testsuite",
    "type": "neos-package",
    "description": "Testing support suite for the Neos Content Repository. Contains fixtures and helpers for all layers of tests",
    "support": {
        "source": "https://github.com/neos/contentrepository-testsuite.git",
        "forum": "https://discuss.neos.io/",
        "docs": "https://docs.neos.io/"
    },
    "license": [
        "GPL-3.0-or-later"
    ],
    "require": {
        "neos/utility-arrays": "*",
        "neos/contentrepository-core": "self.version",
        "behat/behat": "^3.5"
    },
    "suggest": {
        "phpunit/phpunit": "to run assertions in the steps (>=9.6 <13)",
        "neos/contentrepository-structureadjustment": "for certain steps",
        "neos/contentrepository-nodemigration": "for certain steps"
    },
    "autoload": {
        "psr-4": {
            "Neos\\ContentRepository\\TestSuite\\": "Classes"
        }
    }
}
