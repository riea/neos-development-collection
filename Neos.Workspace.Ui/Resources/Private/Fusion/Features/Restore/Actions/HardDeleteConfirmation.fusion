Neos.Workspace.Ui.RestoreController.hardDeleteConfirmation = Neos.Fusion:Component {
  /// string
  nodeAggregateId = ${nodeAggregateId}
  /// string
  nodeLabel = ${nodeLabel}
  /// string
  workspaceName = ${workspaceName}

  renderer = afx`
    <Neos.Workspace.Ui:Component.Modal.HardDeleteConfirmation
      nodeAggregateId={props.nodeAggregateId}
      nodeLabel={props.nodeLabel}
      workspaceName={props.workspaceName}
    />
  `
}
