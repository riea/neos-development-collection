prototype(Neos.Workspace.Ui:Component.Modal.RestoreNodeConfirmation) < prototype(Neos.Fusion:Component) {
  /// string
  nodeAddress = ''
  /// string
  nodeLabel = ''
  /// string
  workspaceName = ''
  /// boolean
  isParentRestore = false

  @private {
    i18n = ${I18n.id('').source('Main').package('Neos.Workspace.Ui')}
    popoverId = 'restore-confirm-modal'

    restoreUri = Neos.Fusion:ActionUri {
      action = 'restoreNode'
      format = 'htmx'
      arguments {
        workspaceName = ${props.workspaceName}
        nodeAggregateId = ${props.nodeAddress}
      }
    }

  }

  renderer = afx`
    <div popover class="success" id={private.popoverId}>
      <header>
        <button
          type="button"
          class="neos-close neos-button"
          popovertarget={private.popoverId}
          popovertargetaction="close"
        >
          <Neos.Workspace.Ui:Component.Icon icon="times"/>
        </button>
        <div class="neos-header">
          <i class="fa-solid fa-circle-question"></i>
          <span @if.isNormalRestore={!props.isParentRestore}> {private.i18n.id('restore.dialog.restore.title')}</span>
          <span @if.isParentRestore={props.isParentRestore}> {private.i18n.id('restore.dialog.parentRestore.title')}</span>
        </div>
      </header>

      <section>


        <p @if.isNormalRestore={!props.isParentRestore}>{private.i18n.id('restore.dialog.restore.text').arguments([props.nodeLabel, props.workspaceName])}</p>
        <p @if.isParentRestore={props.isParentRestore}>{private.i18n.id('restore.dialog.parentRestore.text').arguments([props.nodeLabel, props.workspaceName])}</p>
        <p>{private.i18n.id('restore.dialog.restore.warning')}</p>
      </section>
      <footer>
        <button
          type="button"
          class="neos-button"
          popovertarget={private.popoverId}
          popovertargetaction="close"
        >
          {private.i18n.id('restore.dialog.restore.cancel')}
        </button>

        <Neos.Workspace.Ui:Component.Button
          isSuccess
          label={private.i18n.id('restore.dialog.restore.confirm')}
          attributes.hx-get={private.restoreUri}
          attributes.hx-target='#popover-container'
          attributes.hx-swap='innerHTML'
          attributes.hx-on--after-request={
            '
            (event) => {
              const response = event.detail.xhr.responseText;
              if (!response.includes("restore-confirm-modal")) {
                document.getElementById("' + private.popoverId + '").hidePopover();
              }
            }
            '
          }
        />
      </footer>

    </div>
  `
}
